# MedClaim-Agentic-RAG — local development defaults.
# Copy to .env and adjust. No real secrets here; generate your own for the
# "change-me" values (e.g. `openssl rand -base64 32`).

# ── Qdrant ────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=medclaim_chunks
# Only needed for Qdrant Cloud (roadmap step 10 free-tier deployment); blank
# for local Docker (no auth). Cloud also needs QDRANT_URL set to your
# cluster's https:// endpoint.
QDRANT_API_KEY=

# ── Neo4j (Community Edition) ─────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=medclaim-local-dev
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
# Lean defaults sized for an 8 GB laptop; raise for the 100k-doc load test.
NEO4J_HEAP_INITIAL=256m
NEO4J_HEAP_MAX=512m
NEO4J_PAGECACHE=256m

# ── Redis (four roles — see README §6; Phase 1 uses L3 + Celery) ──────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# L3 embedding-cache TTL in seconds; 0 = keep forever.
L3_EMBEDDING_CACHE_TTL=0

# ── Docling parsing ───────────────────────────────────────────────────────
# OCR is off by default (digital-born PDFs don't need it; the OCR models cost
# several hundred MB of RAM). Set to 1 when ingesting scanned documents.
DOCLING_DO_OCR=0
# Pages processed per batch; 1 = lowest peak memory.
DOCLING_PAGE_BATCH_SIZE=1

# ── Embeddings (local, CPU, via fastembed) ────────────────────────────────
# Low-RAM machines (< 8 GB free): use BAAI/bge-small-en-v1.5 with
# EMBEDDING_DIM=384 (~4x smaller ONNX model, slightly lower recall).
# Changing the model/dim requires recreating the Qdrant collection.
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIM=768
EMBED_BATCH_SIZE=96

# ── Chunking (README §5) ──────────────────────────────────────────────────
CHUNK_MIN_TOKENS=512
CHUNK_MAX_TOKENS=1024
CHUNK_TARGET_TOKENS=768
CHUNK_OVERLAP_TOKENS=100
PARENT_MAX_TOKENS=3072

# ── Retrieval + reranking (roadmap step 3) ────────────────────────────────
# Cross-encoder rescoring after RRF fusion. ~1 GB RAM when loaded; set
# RERANKER_ENABLED=0 on low-memory machines (results keep the RRF order and
# are marked reranked=false).
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_ENABLED=1
RETRIEVAL_TOP_K=8
RETRIEVAL_VECTOR_TOP_N=20
RETRIEVAL_GRAPH_TOP_N=20
RETRIEVAL_RRF_K=60
RETRIEVAL_RERANK_CANDIDATES=16

# ── GraphRAG scoping (README §3): comma-separated source_types that get
#    chunk nodes + REFERENCES edges in Neo4j. claim_note stays vector-only.
GRAPH_SCOPED_SOURCE_TYPES=policy,clinical_guideline

# ── Agent / LLM (roadmap step 4) ──────────────────────────────────────────
# Any Ollama-compatible endpoint: local Ollama, or a Colab GPU tunnel URL.
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=medclaim-llm
# Optional: separate (stronger) model for LLM-as-judge scoring; defaults to
# LLM_MODEL. A 3B judge is erratic — see RUNME troubleshooting.
# LLM_JUDGE_MODEL=
# Judge score below this pauses the answer for human review (0..1).
JUDGE_THRESHOLD=0.6

# ── Guardrails + grounding (roadmap step 5, README §8/§10) ────────────────
# Per-sentence NLI entailment of the answer against its cited chunks.
# ~280 MB RAM when loaded; GROUNDING_ENABLED=0 skips it (answers marked
# grounding_checked=false).
GROUNDING_MODEL=cross-encoder/nli-deberta-v3-xsmall
GROUNDING_ENABLED=1
# Sentence counts as grounded when max entailment prob >= this.
ENTAILMENT_THRESHOLD=0.5
# Grounded fraction below this routes the answer to human review.
GROUNDING_REVIEW_THRESHOLD=0.8

# ── Langfuse (self-hosted) ────────────────────────────────────────────────
LANGFUSE_PORT=3000
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=change-me-langfuse-db
LANGFUSE_DB_NAME=langfuse
LANGFUSE_NEXTAUTH_SECRET=change-me-generate-a-real-secret
LANGFUSE_SALT=change-me-generate-a-real-salt
# Filled in after first login (Langfuse UI → project settings). When both
# keys are set, every scripts/ask.py run emits a full trace (node spans, LLM
# generations with token counts, judge score) to the self-hosted instance.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ── LangSmith (dev-time tracing, README §11) — optional, zero-code ────────
# Uncomment with a key from smith.langchain.com; LangGraph traces itself.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=medclaim-agentic-rag
